[Unit]
Description=Highland Media Services — AV Equipment Inventory
After=network.target

[Service]
Type=simple
User=REDACTED
WorkingDirectory=/var/www/html/inventory.REDACTEDmediaservices.com
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=10
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=hms-inventory
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
